# MongoDB connection string (local or Atlas)
MONGO_URI=

# Signing key for JWT (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Server port (production build / `npm start`)
PORT=8080

# Allow POST /api/auth/register with role doctor|admin (default off; use seed script for staff)
ALLOW_STAFF_REGISTER=false

# Optional: overrides /api/ping message
# PING_MESSAGE=ping
